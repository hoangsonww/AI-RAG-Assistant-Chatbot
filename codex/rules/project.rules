# Allow common build validation commands to run outside the sandbox without prompting.
prefix_rule(
    pattern = ["npm", "run", "build"],
    decision = "allow",
    justification = "Build validation is a standard non-destructive check in this repository.",
    match = [
        "npm run build",
    ],
    not_match = [
        "npm run dev",
    ],
)

# Allow low-risk Python compile validation.
prefix_rule(
    pattern = ["python", "-m", "compileall"],
    decision = "allow",
    justification = "Bytecode compilation is a safe validation step for Python changes.",
    match = [
        "python -m compileall agentic_ai",
    ],
    not_match = [
        "python -m agentic_ai server",
    ],
)

# Prompt before knowledge-base mutation or interactive knowledge commands.
prefix_rule(
    pattern = ["npm", "run", ["knowledge:repl", "knowledge:upsert", "knowledge:delete", "knowledge:sync"]],
    decision = "prompt",
    justification = "Knowledge commands can mutate indexed content or start an interactive session.",
    match = [
        "npm run knowledge:repl",
        "npm run knowledge:upsert -- --title Resume --file ./knowledge/resume.txt --type resume --external-id resume-2025",
        "npm run knowledge:delete -- --id abc123",
        "npm run knowledge:sync -- --manifest ./knowledge/manifest.json",
    ],
    not_match = [
        "npm run knowledge:list",
    ],
)

# Prompt before starting long-running Python pipeline or MCP commands.
prefix_rule(
    pattern = ["python", "-m", "agentic_ai"],
    decision = "prompt",
    justification = "Agentic pipeline commands may start long-running processes or require external services.",
    match = [
        "python -m agentic_ai visualize",
        "python -m agentic_ai server --config agentic_ai/config/production_config.yaml",
    ],
    not_match = [
        "python -m compileall agentic_ai",
    ],
)

# Allow read-only knowledge listing without prompting.
prefix_rule(
    pattern = ["npm", "run", "knowledge:list"],
    decision = "allow",
    justification = "Listing knowledge sources is a read-only operation.",
    match = [
        "npm run knowledge:list",
    ],
    not_match = [
        "npm run knowledge:upsert",
    ],
)

# Allow git status and diff commands for investigation.
prefix_rule(
    pattern = ["git", ["status", "diff", "log", "blame"]],
    decision = "allow",
    justification = "Read-only Git commands are safe for codebase investigation.",
    match = [
        "git status",
        "git diff HEAD",
        "git log --oneline -10",
        "git blame server/src/server.ts",
    ],
    not_match = [
        "git push origin main",
        "git commit -m test",
    ],
)

# Allow Terraform validation commands.
prefix_rule(
    pattern = ["terraform", ["validate", "fmt"]],
    decision = "allow",
    justification = "Terraform validation and formatting checks are non-destructive.",
    match = [
        "terraform validate",
        "terraform fmt -check",
    ],
    not_match = [
        "terraform apply",
        "terraform destroy",
    ],
)

# Prompt before Terraform apply or destroy.
prefix_rule(
    pattern = ["terraform", ["apply", "destroy", "import"]],
    decision = "prompt",
    justification = "Terraform state-changing commands require explicit approval.",
    match = [
        "terraform apply",
        "terraform destroy",
    ],
    not_match = [
        "terraform validate",
    ],
)

# Allow Docker Compose config validation.
prefix_rule(
    pattern = ["docker", "compose", "config"],
    decision = "allow",
    justification = "Docker Compose config validation is read-only.",
    match = [
        "docker compose config",
    ],
    not_match = [
        "docker compose up",
    ],
)

# Prompt before Docker Compose up/down/build.
prefix_rule(
    pattern = ["docker", "compose", ["up", "down", "build", "restart"]],
    decision = "prompt",
    justification = "Docker Compose lifecycle commands affect running containers.",
    match = [
        "docker compose up --build",
        "docker compose down",
    ],
    not_match = [
        "docker compose config",
    ],
)

# Allow standalone MCP server compile check.
prefix_rule(
    pattern = ["python", "-m", "compileall", "mcp_server"],
    decision = "allow",
    justification = "Bytecode compilation of the MCP server is a safe validation step.",
    match = [
        "python -m compileall mcp_server",
    ],
    not_match = [
        "python -m mcp_server",
    ],
)

# Prompt before starting the MCP server.
prefix_rule(
    pattern = ["python", "-m", "mcp_server"],
    decision = "prompt",
    justification = "Starting the MCP server may bind ports or start long-running processes.",
    match = [
        "python -m mcp_server",
        "python -m mcp_server --transport sse --port 8080",
    ],
    not_match = [
        "python -m compileall mcp_server",
    ],
)

# Forbid direct environment file modification.
prefix_rule(
    pattern = ["cat", [".env", "server/.env", "client/.env"]],
    decision = "forbidden",
    justification = "Environment files may contain secrets. Use environment variables directly instead.",
    match = [
        "cat .env",
        "cat server/.env",
    ],
    not_match = [
        "cat .env.example",
    ],
)
